{
  "routes": [
    { "src": "/directory", "dest": "/directory.html" },
    { "src": "/directory.html", "dest": "/directory.html" },
    { "src": "/index.html", "dest": "/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
